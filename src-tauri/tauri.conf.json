{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flobro",
  "version": "1.1.0",
  "identifier": "app.flobro.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "launcher",
        "title": "Flobro",
        "url": "index.html",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["flobro"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE5QUE0QkYzNkQ4NkU2MjUKUldRbDVvWnQ4MHVxR1Z0Q05FL2poekFVTUMwYWRiVVB0VkFVMDN5dnB3UXAyUlQyM01CMy9lMVIK",
      "endpoints": ["https://github.com/flobro/flobro-app/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
