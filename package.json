{
  "name": "flobro-app",
  "version": "1.2.0",
  "private": true,
  "description": "Flobro desktop app for Mac and Windows, built with Tauri 2 (Rust + system webview).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks');require('fs').readdirSync('.githooks').forEach(f=>require('fs').chmodSync('.githooks/'+f,0o755))}catch(e){}\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4"
  }
}
