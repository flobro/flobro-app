{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!node_modules", "!src-tauri/target", "!src-tauri/gen", "!src-tauri/icons"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "useTemplate": "off",
        "noDescendingSpecificity": "off"
      },
      "complexity": {
        "useArrowFunction": "off",
        "useOptionalChain": "off"
      },
      "suspicious": {
        "noRedundantUseStrict": "off"
      },
      "correctness": {
        "noInnerDeclarations": "off"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "noAutofocus": "off"
      }
    }
  },
  "assist": {
    "enabled": true
  }
}
